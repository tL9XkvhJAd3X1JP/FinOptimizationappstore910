<?xml version="1.0" encoding="utf-8"?>
<library.slidinguppanel.SlidingUpPanelLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:sothree="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mSlidingLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="bottom"
    sothree:umanoDragView="@+id/dragView"
    sothree:umanoInitialState="expanded"
    sothree:umanoOverlay="true"
    sothree:umanoPanelHeight="@dimen/y37"
    sothree:umanoParallaxOffset="0dp"
    sothree:umanoShadowHeight="0dp">


    <com.baidu.mapapi.map.MapView
        android:id="@+id/bmapView"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/white"
        android:clickable="true" />

    <LinearLayout
        android:id="@+id/dragView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="@dimen/y12"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/icon_drag" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_sn_code"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/y25"
                android:layout_marginLeft="@dimen/x10"
                android:layout_marginRight="@dimen/x10"
                android:gravity="center_vertical"
                android:textColor="@color/black2" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/x10"
                android:layout_marginTop="@dimen/x6"
                android:layout_marginRight="@dimen/x10"
                android:text="查询时间"
                android:textColor="@color/black2" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/x12"
                android:layout_marginTop="@dimen/x6"
                android:layout_marginRight="@dimen/x12"
                android:orientation="horizontal">

                <RelativeLayout
                    android:id="@+id/rl_start_date"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_weight="2"
                    android:background="@drawable/shape_bg_input_blue9"
                    android:paddingLeft="@dimen/x6"
                    android:paddingRight="@dimen/x6">

                    <TextView
                        android:id="@+id/tv_start_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="开始时间"
                        android:textColor="@color/black2" />

                    <ImageView
                        android:id="@+id/iv_start_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/icon_data" />

                    <TextView
                        android:id="@+id/tv_start_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="@dimen/x4"
                        android:layout_toLeftOf="@id/iv_start_title"
                        android:layout_toRightOf="@id/tv_start_title"
                        android:lines="1"
                        android:textColor="@color/black2" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/rl_start_time"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="3"
                    android:background="@drawable/shape_bg_input_blue9"
                    android:paddingLeft="@dimen/x6"
                    android:paddingRight="@dimen/x6">

                    <TextView
                        android:id="@+id/tv_start_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:textColor="@color/black2" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/icon_time" />

                </RelativeLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/x12"
                android:layout_marginTop="@dimen/x8"
                android:layout_marginRight="@dimen/x12"
                android:orientation="horizontal">

                <RelativeLayout
                    android:id="@+id/rl_end_date"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_weight="2"
                    android:background="@drawable/shape_bg_input_blue9"
                    android:paddingLeft="@dimen/x6"
                    android:paddingRight="@dimen/x6">

                    <TextView
                        android:id="@+id/tv_end_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="结束时间"
                        android:textColor="@color/black2" />

                    <ImageView
                        android:id="@+id/iv_end_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/icon_data" />

                    <TextView
                        android:id="@+id/tv_end_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="@dimen/x4"
                        android:layout_toLeftOf="@id/iv_end_title"
                        android:layout_toRightOf="@id/tv_end_title"
                        android:lines="1"
                        android:textColor="@color/black2" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/rl_end_time"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="3"
                    android:background="@drawable/shape_bg_input_blue9"
                    android:paddingLeft="@dimen/x6"
                    android:paddingRight="@dimen/x6">

                    <TextView
                        android:id="@+id/tv_end_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:textColor="@color/black2" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/icon_time" />

                </RelativeLayout>


            </LinearLayout>

            <TextView
                android:id="@+id/tv_search"
                android:layout_width="match_parent"
                android:layout_height="@dimen/x32"
                android:layout_marginLeft="@dimen/x12"
                android:layout_marginTop="@dimen/x8"
                android:layout_marginRight="@dimen/x12"
                android:background="@drawable/selector_bg_btn_black13_to_blue9"
                android:gravity="center"
                android:text="查询"
                android:textColor="@color/white" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/x8"
                android:background="@color/gray4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/x12"
                android:layout_marginTop="@dimen/x8"
                android:layout_marginRight="@dimen/x12"
                android:orientation="horizontal">


                <RelativeLayout
                    android:id="@+id/rl_speed_choise"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_weight="3"
                    android:background="@drawable/shape_bg_input_blue9"
                    android:paddingLeft="@dimen/x6"
                    android:paddingRight="@dimen/x6">

                    <TextView
                        android:id="@+id/tv_speed_choise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="匀速回放"
                        android:textColor="@color/black2" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/icon_down" />


                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/rl_start_move"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="2"
                    android:background="@drawable/selector_bg_btn_blue9_to_black13">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:drawableLeft="@drawable/icon_start"
                        android:drawablePadding="@dimen/x4"
                        android:gravity="center_vertical"
                        android:text="开始"
                        android:textColor="@color/white" />

                </RelativeLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/x12"
                android:layout_marginTop="@dimen/x8"
                android:layout_marginRight="@dimen/x12"
                android:layout_marginBottom="@dimen/x8"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_stop_move"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_weight="1"
                    android:background="@drawable/selector_bg_btn_black13_to_blue9"
                    android:gravity="center"
                    android:text="暂停"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_continue_move"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_marginLeft="15dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_bg_btn_black13_to_blue9"
                    android:gravity="center"
                    android:text="继续"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_hide"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/x32"
                    android:layout_marginLeft="15dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_bg_btn_black13_to_blue9"
                    android:gravity="center"
                    android:text="隐藏"
                    android:textColor="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>


</library.slidinguppanel.SlidingUpPanelLayout>